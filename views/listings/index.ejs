<% layout("/layouts/boilerplate.ejs")%>
<%= %>


<Style>
    .filter{
        margin-top: 1rem;
        text-align: center;
        margin-right: 2.5rem;
        margin-top: 1rem;
        opacity: 0.7;
    }
    #filters{
        display: flex;
        flex-wrap: wrap ;
       
    }
    .filter:hover {
        opacity: 1;
        cursor: pointer;
    }
    .filter p{
        font-size: 0.8rem;
    }
    .filter a{
    text-decoration: none;
    color: black;
}
</Style>
   
  <div id="filters">
      <div class="filter">
       <div> <i class="fa-solid fa-fire"></i></div>
        <p> <a href="/listings/category/Trending">Trending</a></p>

      </div>

    
      <div class="filter">
       <div> <i class="fa-solid fa-bed"></i></div>
        <p> <a href="/listings/category/Rooms">Rooms</a> </p>

      </div>

      
      <div class="filter">
       <div> <i class="fa-solid fa-mountain-city"></i></div>
        <p> <a href="/listings/category/Mountain">Iconic cities</a>I</p>

      </div>

      <div class="filter">
       <div> <i class="fa-brands fa-fort-awesome"></i></div>
        <p> <a href="/listings/category/Castle">Castes</a></p>
      </div>

      <div class="filter">
       <div> <i class="fa-solid fa-person-swimming"></i></div>
        <p><a href="/listings/category/Pool">Pools</a></p>
      </div>

      <div class="filter">
       <div><i class="fa-solid fa-campground"></i></div>
        <p><a href="/listings/category/Camping">Comping</a></p>
      </div>

      <div class="filter">
       <div><i class="fa-solid fa-cow"></i></div>
        <p><a href="/listings/category/Farms">Farms</a></p>
      </div>
       
      <div class="filter">
       <div><i class="fa-brands fa-galactic-republic"></i></div>
        <p><a href="/listings/category/Arctic">Arctic</a></p>
      </div>

      
       
  </div>
    <div class="row row-cols-lg-3 row-cols-md-2 row-cols-sm-1 mt-3">
    <% for(let listing of allListings){ %>
        <a  href="/listings/<%=listing._id%>" class="listing-link">
        <div class="card col listing-card" >
            <img src="<%=listing.image.url%>" class="card-img-top" alt="listing_image" style="height: 20rem;">
            <div class="card-img-overlay"></div>
            
            <div class="card-body">
                <p class="card-text">
                    <b> <%=listing.title%> </b> <br> 
                        &#8377;<%= listing.price ? listing.price.toLocaleString("en-IN") : "0" %>/night
                       
    
                </p>
            </div>
        </div>
        <%} %>
    </div>
    </a>



